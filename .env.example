# Gemini API key for voice agent (Live API)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Live model and voice
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE=Aoede

# Restaurant timezone (always state IST to callers)
RESTAURANT_TIMEZONE=Asia/Kolkata

# Google Workspace — service account JSON (download from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_PATH=service-account.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_SHEET_NAME=Sheet1

# Legacy OAuth desktop flow (optional if using service account above)
# GOOGLE_CREDENTIALS_PATH=credentials.json
# GOOGLE_TOKEN_PATH=token.json

# Mock mode: skip real Google API calls (useful for demos)
MOCK_GOOGLE_INTEGRATIONS=false

# --- Vercel production (set in Vercel dashboard, not locally) ---
# RESERVATIONS_DATA_DIR=/tmp/data
# GOOGLE_SERVICE_ACCOUNT_PATH=   # use GOOGLE_CREDENTIALS_JSON on Vercel instead
# GOOGLE_CREDENTIALS_JSON=       # paste full service account JSON as one line
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# Server (local dev)
HOST=0.0.0.0
PORT=8000
